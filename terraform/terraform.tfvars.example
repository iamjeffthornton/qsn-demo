# ============================================================
# terraform.tfvars.example — Example values per rugby coverage
# ============================================================
# IMPORTANT:
#   Copy this file to terraform.tfvars and fill in real values.
#   terraform.tfvars is in .gitignore — it NEVER goes to GitHub
#   because it contains your actual Anthropic API key.
#
#   This .example file IS safe to commit to GitHub — it shows
#   the structure without any real secrets inside it.
# ============================================================


# ---- USA EAGLES / AMERICAS RUGBY COVERAGE ----
league_name       = "usaeagles"
environment       = "production"
location          = "eastus"
owner_name        = "Jeff Thornton"
node_vm_size      = "Standard_D4s_v3"
replica_count     = 3
alert_email       = "jeff@jeffreythornton.com"
anthropic_api_key = "sk-ant-YOUR-KEY-HERE"    # never commit a real key!


