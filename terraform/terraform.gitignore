# ============================================================
# .gitignore — Files that NEVER go to GitHub
# ============================================================
# CRITICAL: Never commit secrets or Terraform state to GitHub.
# This file tells Git to ignore them automatically.
# ============================================================

# ---- SECRETS — never commit these ----
# terraform.tfvars contains your real Anthropic API key
terraform.tfvars
*.tfvars
!*.tfvars.example     # .example files ARE safe to commit

# ---- TERRAFORM STATE — never commit these ----
# The state file tracks what Terraform built.
# It can contain sensitive values in plain text.
# Use remote state (Azure Blob) for team environments.
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info

# ---- TERRAFORM WORKING DIRECTORY ----
# Downloaded providers and modules — large binary files
# Recreated by running "terraform init"
.terraform/
.terraform.lock.hcl

# ---- CRASH LOGS ----
crash.log
crash.*.log

# ---- OVERRIDE FILES ----
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ---- PLAN OUTPUT FILES ----
# terraform plan -out=myplan saves a binary plan file
# These may contain sensitive values
*.tfplan
